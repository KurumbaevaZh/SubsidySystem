<Window x:Class="SubsidySystem.Views.FamilyMemberWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Внесение членов семьи" Height="650" Width="800"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Выбор заявителя -->
        <GroupBox Header="Выбор заявителя" Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Margin="10">
                <ComboBox ItemsSource="{Binding Citizens}" 
                          SelectedItem="{Binding SelectedCitizen}"
                          DisplayMemberPath="FullName" 
                          Margin="0,5"/>
            </StackPanel>
        </GroupBox>

        <!-- Форма добавления/редактирования члена семьи -->
        <GroupBox Header="Данные члена семьи" Grid.Row="1" Margin="0,0,0,10">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Фамилия:" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding FamilyMember.LastName, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Имя:" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding FamilyMember.FirstName, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Отчество:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding FamilyMember.MiddleName, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="Родственная связь:" VerticalAlignment="Center" FontWeight="Bold"/>
                <ComboBox Grid.Row="1" Grid.Column="3" ItemsSource="{Binding Relationships}" 
                          SelectedItem="{Binding FamilyMember.Relationship, UpdateSourceTrigger=PropertyChanged}"
                          Margin="0,5"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Дата рождения:" VerticalAlignment="Center" FontWeight="Bold"/>
                <DatePicker Grid.Row="2" Grid.Column="1" SelectedDate="{Binding FamilyMember.BirthDate, UpdateSourceTrigger=PropertyChanged}" 
                            Margin="0,5" />

                <TextBlock Grid.Row="2" Grid.Column="2" Text="Учащийся:" VerticalAlignment="Center"/>
                <CheckBox Grid.Row="2" Grid.Column="3" IsChecked="{Binding FamilyMember.IsStudent}" 
                          VerticalAlignment="Center" Margin="0,5"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="СНИЛС:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding FamilyMember.Snils, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>

                <TextBlock Grid.Row="3" Grid.Column="2" Text="Примечание:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="3" Grid.Column="3" Text="{Binding FamilyMember.Notes, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>

                <!-- Кнопки управления -->
                <StackPanel Grid.Row="4" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                    <Button Content="Добавить" Command="{Binding AddCommand}" Width="90" Height="30" Margin="5"
                            Background="#2E7D32" Foreground="White"/>
                    <Button Content="Обновить" Command="{Binding UpdateCommand}" Width="90" Height="30" Margin="5"
                            Background="#1565C0" Foreground="White"/>
                    <Button Content="Удалить" Command="{Binding DeleteCommand}" Width="90" Height="30" Margin="5"
                            Background="#D32F2F" Foreground="White"/>
                    <Button Content="Очистить" Command="{Binding ClearCommand}" Width="90" Height="30" Margin="5"
                            Background="#757575" Foreground="White"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Список членов семьи -->
        <GroupBox Header="Список членов семьи" Grid.Row="2" Margin="0,0,0,10">
            <DataGrid ItemsSource="{Binding FamilyMembers}" 
                      SelectedItem="{Binding SelectedFamilyMember}"
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#F5F5F5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="120"/>
                    <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="100"/>
                    <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName}" Width="100"/>
                    <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Родственная связь" Binding="{Binding Relationship}" Width="100"/>
                    <DataGridTextColumn Header="Учащийся" Width="80">
                        <DataGridTextColumn.Binding>
                            <Binding Path="IsStudent" StringFormat="{}{0:Да;Нет}"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="СНИЛС" Binding="{Binding Snils}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- Кнопка Назад -->
        <Button Grid.Row="3" Content="◀ Назад" Click="BackButton_Click" Width="120" Height="35" Margin="5"
                Background="#1565C0" Foreground="White" HorizontalAlignment="Center"/>

        <!-- Статус -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Foreground="Gray" FontSize="11" TextWrapping="Wrap" Margin="0,40,0,0"/>
    </Grid>
</Window>