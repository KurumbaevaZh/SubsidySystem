<Window x:Class="SubsidySystem.Views.ApproveRegistriesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Утверждение реестров выплат" Height="600" Width="1000"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#1565C0" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Утверждение реестров выплат" FontSize="18" FontWeight="Bold" Foreground="White"/>
                <Button Content="🔄 Обновить" Command="{Binding RefreshCommand}" 
                        Width="100" Height="30" Margin="20,0,0,0"
                        Background="#FF8F00" Foreground="White"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Список реестров -->
            <GroupBox Header="Реестры на утверждение" Grid.Column="0">
                <DataGrid ItemsSource="{Binding Registries}" 
                          SelectedItem="{Binding SelectedRegistry}"
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№ реестра" Binding="{Binding RegistryNumber}" Width="100"/>
                        <DataGridTextColumn Header="Дата" Binding="{Binding RegistryDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Период" Width="100">
                            <DataGridTextColumn.Binding>
                                <MultiBinding StringFormat="{}{0:00}.{1}">
                                    <Binding Path="PeriodMonth"/>
                                    <Binding Path="PeriodYear"/>
                                </MultiBinding>
                            </DataGridTextColumn.Binding>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount, StringFormat=N2}" Width="120"/>
                        <DataGridTextColumn Header="Кол-во получателей" Binding="{Binding RecipientCount}" Width="120"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="LightGray"/>

            <!-- Детали выплат -->
            <GroupBox Header="Выплаты в реестре" Grid.Column="2">
                <DataGrid ItemsSource="{Binding Payments}" 
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Тип выплаты" Binding="{Binding PaymentType}" Width="100"/>
                        <DataGridTextColumn Header="Сумма" Binding="{Binding PaymentAmount, StringFormat=N2}" Width="100"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>

        <!-- Кнопки действий -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="✅ Утвердить" Command="{Binding ApproveCommand}" 
                    Width="150" Height="40" Margin="10"
                    Background="#2E7D32" Foreground="White"
                    FontWeight="Bold"/>
            <Button Content="❌ Отклонить" Command="{Binding RejectCommand}" 
                    Width="150" Height="40" Margin="10"
                    Background="#D32F2F" Foreground="White"
                    FontWeight="Bold"/>
            <Button Content="◀ Назад" Click="BackButton_Click" Width="150" Height="40" Margin="10"
                    Background="#1565C0" Foreground="White" FontWeight="Bold"/>
        </StackPanel>

        <!-- Статус -->
        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="Gray" FontSize="11" 
                   HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,5"/>
    </Grid>
</Window>