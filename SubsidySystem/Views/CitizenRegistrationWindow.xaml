<Window x:Class="SubsidySystem.Views.CitizenRegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация заявителя" Height="650" Width="750"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="4" Text="Регистрация нового заявителя" 
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>

        <!-- Фамилия -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Фамилия:" VerticalAlignment="Center" FontWeight="Bold"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Citizen.LastName, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>

        <!-- Имя -->
        <TextBlock Grid.Row="1" Grid.Column="2" Text="Имя:" VerticalAlignment="Center" FontWeight="Bold"/>
        <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding Citizen.FirstName, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>

        <!-- Отчество -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Отчество:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Citizen.MiddleName, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>

        <!-- Дата рождения -->
        <TextBlock Grid.Row="2" Grid.Column="2" Text="Дата рождения:" VerticalAlignment="Center" FontWeight="Bold"/>
        <DatePicker Grid.Row="2" Grid.Column="3" SelectedDate="{Binding Citizen.BirthDate, UpdateSourceTrigger=PropertyChanged}" 
                    Margin="0,5"/>

        <!-- СНИЛС -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="СНИЛС:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Citizen.Snils, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>

        <!-- Серия паспорта -->
        <TextBlock Grid.Row="3" Grid.Column="2" Text="Серия паспорта:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="3" Grid.Column="3" Text="{Binding Citizen.PassportSeries, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>

        <!-- Номер паспорта -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Номер паспорта:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Citizen.PassportNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>

        <!-- Кем выдан паспорт -->
        <TextBlock Grid.Row="4" Grid.Column="2" Text="Кем выдан:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="4" Grid.Column="3" Text="{Binding Citizen.PassportIssuer, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>

        <!-- Дата выдачи паспорта -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Дата выдачи:" VerticalAlignment="Center"/>
        <DatePicker Grid.Row="5" Grid.Column="1" SelectedDate="{Binding Citizen.PassportIssueDate, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>

        <!-- Адрес регистрации -->
        <TextBlock Grid.Row="5" Grid.Column="2" Text="Адрес регистрации:" VerticalAlignment="Center" FontWeight="Bold"/>
        <TextBox Grid.Row="5" Grid.Column="3" Text="{Binding Citizen.RegistrationAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>

        <!-- Фактический адрес -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Фактический адрес:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Citizen.ActualAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>

        <!-- Телефон -->
        <TextBlock Grid.Row="7" Grid.Column="0" Text="Телефон:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding Citizen.Phone, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>

        <!-- Категория льготности -->
        <TextBlock Grid.Row="7" Grid.Column="2" Text="Категория льготности:" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="7" Grid.Column="3" ItemsSource="{Binding Categories}" 
                  SelectedItem="{Binding SelectedCategory}" DisplayMemberPath="CategoryName"
                  Margin="0,5"/>

        <!-- Примечание -->
        <TextBlock Grid.Row="8" Grid.Column="0" Text="Примечание:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Citizen.Notes, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="0,5" Height="60" TextWrapping="Wrap"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="9" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
            <Button Content="Сохранить" Command="{Binding SaveCommand}" Width="120" Height="35" Margin="5"
                    Background="#2E7D32" Foreground="White"/>
            <Button Content="Очистить" Command="{Binding CancelCommand}" Width="120" Height="35" Margin="5"
                    Background="#757575" Foreground="White"/>
            <Button Content="◀ Назад" Click="BackButton_Click" Width="120" Height="35" Margin="5"
                    Background="#1565C0" Foreground="White"/>
        </StackPanel>

        <!-- Статус -->
        <TextBlock Grid.Row="10" Grid.ColumnSpan="4" Text="{Binding StatusMessage}" 
                   Foreground="Gray" FontSize="11" TextWrapping="Wrap"/>
    </Grid>
</Window>