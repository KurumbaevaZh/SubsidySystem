<Window x:Class="SubsidySystem.Views.DictionariesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление справочниками" Height="600" Width="900"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <!-- Вкладка: Категории граждан -->
            <TabItem Header="📋 Категории граждан">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="Добавление/Редактирование" Grid.Row="0">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Наименование:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBox Text="{Binding Category.CategoryName, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1" Margin="5"/>

                            <TextBlock Text="Скидка %:" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding Category.DiscountRate, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="3" Margin="5"/>

                            <TextBlock Text="Условия:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding Category.EligibilityConditions, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Margin="5" Height="60" TextWrapping="Wrap"/>

                            <TextBlock Text="Нормативный акт:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding Category.RegulatoryAct, UpdateSourceTrigger=PropertyChanged}" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Margin="5"/>

                            <StackPanel Grid.Row="3" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                                <Button Content="Добавить" Command="{Binding AddCategoryCommand}" Width="90" Height="30" Margin="5"
                                        Background="#2E7D32" Foreground="White"/>
                                <Button Content="Обновить" Command="{Binding UpdateCategoryCommand}" Width="90" Height="30" Margin="5"
                                        Background="#1565C0" Foreground="White"/>
                                <Button Content="Удалить" Command="{Binding DeleteCategoryCommand}" Width="90" Height="30" Margin="5"
                                        Background="#D32F2F" Foreground="White"/>
                                <Button Content="Очистить" Command="{Binding ClearCategoryCommand}" Width="90" Height="30" Margin="5"
                                        Background="#757575" Foreground="White"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Список категорий" Grid.Row="1" Margin="0,10">
                        <DataGrid ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" 
                                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding CategoryId}" Width="50"/>
                                <DataGridTextColumn Header="Наименование" Binding="{Binding CategoryName}" Width="200"/>
                                <DataGridTextColumn Header="Скидка %" Binding="{Binding DiscountRate}" Width="80"/>
                                <DataGridTextColumn Header="Условия" Binding="{Binding EligibilityConditions}" Width="*"/>
                                <DataGridTextColumn Header="Нормативный акт" Binding="{Binding RegulatoryAct}" Width="200"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>

                    <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="Gray" FontSize="11"/>
                </Grid>
            </TabItem>

            <!-- Вкладка: Виды доходов -->
            <TabItem Header="💰 Виды доходов">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="Добавление/Редактирование" Grid.Row="0">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Наименование:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBox Text="{Binding IncomeType.IncomeTypeName, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1" Margin="5"/>

                            <TextBlock Text="Учитывается:" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center"/>
                            <CheckBox IsChecked="{Binding IncomeType.IsConsidered}" Grid.Row="0" Grid.Column="3" Margin="5" VerticalAlignment="Center"/>

                            <StackPanel Grid.Row="2" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                                <Button Content="Добавить" Command="{Binding AddIncomeTypeCommand}" Width="90" Height="30" Margin="5"
                                        Background="#2E7D32" Foreground="White"/>
                                <Button Content="Обновить" Command="{Binding UpdateIncomeTypeCommand}" Width="90" Height="30" Margin="5"
                                        Background="#1565C0" Foreground="White"/>
                                <Button Content="Удалить" Command="{Binding DeleteIncomeTypeCommand}" Width="90" Height="30" Margin="5"
                                        Background="#D32F2F" Foreground="White"/>
                                <Button Content="Очистить" Command="{Binding ClearIncomeTypeCommand}" Width="90" Height="30" Margin="5"
                                        Background="#757575" Foreground="White"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Список видов доходов" Grid.Row="1" Margin="0,10">
                        <DataGrid ItemsSource="{Binding IncomeTypes}" SelectedItem="{Binding SelectedIncomeType}" 
                                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding IncomeTypeId}" Width="50"/>
                                <DataGridTextColumn Header="Наименование" Binding="{Binding IncomeTypeName}" Width="250"/>
                                <DataGridTextColumn Header="Учитывается" Width="100">
                                    <DataGridTextColumn.Binding>
                                        <Binding Path="IsConsidered" StringFormat="{}{0:Да;Нет}"/>
                                    </DataGridTextColumn.Binding>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>

                    <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="Gray" FontSize="11"/>
                </Grid>
            </TabItem>

            <!-- Вкладка: Виды услуг ЖКУ -->
            <TabItem Header="🔧 Виды услуг ЖКУ">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="Добавление/Редактирование" Grid.Row="0">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Наименование:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBox Text="{Binding UtilityServiceType.ServiceTypeName, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1" Margin="5"/>

                            <TextBlock Text="Ед. измерения:" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding UtilityServiceType.UnitOfMeasure, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="3" Margin="5"/>

                            <StackPanel Grid.Row="2" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                                <Button Content="Добавить" Command="{Binding AddUtilityServiceTypeCommand}" Width="90" Height="30" Margin="5"
                                        Background="#2E7D32" Foreground="White"/>
                                <Button Content="Обновить" Command="{Binding UpdateUtilityServiceTypeCommand}" Width="90" Height="30" Margin="5"
                                        Background="#1565C0" Foreground="White"/>
                                <Button Content="Удалить" Command="{Binding DeleteUtilityServiceTypeCommand}" Width="90" Height="30" Margin="5"
                                        Background="#D32F2F" Foreground="White"/>
                                <Button Content="Очистить" Command="{Binding ClearUtilityServiceTypeCommand}" Width="90" Height="30" Margin="5"
                                        Background="#757575" Foreground="White"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Список видов услуг" Grid.Row="1" Margin="0,10">
                        <DataGrid ItemsSource="{Binding UtilityServiceTypes}" SelectedItem="{Binding SelectedUtilityServiceType}" 
                                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding ServiceTypeId}" Width="50"/>
                                <DataGridTextColumn Header="Наименование" Binding="{Binding ServiceTypeName}" Width="250"/>
                                <DataGridTextColumn Header="Ед. измерения" Binding="{Binding UnitOfMeasure}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>

                    <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="Gray" FontSize="11"/>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,10">
            <Button Content="◀ Назад" Click="BackButton_Click" Width="120" Height="35" Background="#1565C0" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>