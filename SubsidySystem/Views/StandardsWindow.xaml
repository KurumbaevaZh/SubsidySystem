<Window x:Class="SubsidySystem.Views.StandardsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление нормативами" Height="550" Width="800"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Форма добавления/редактирования -->
        <GroupBox Header="Данные норматива" Grid.Row="0" Margin="0,0,0,10">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Тип норматива:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold"/>
                <ComboBox ItemsSource="{Binding StandardTypes}" 
                          SelectedItem="{Binding Standard.StandardType, UpdateSourceTrigger=PropertyChanged}" 
                          Grid.Row="0" Grid.Column="1" Margin="5" IsEditable="True"/>

                <TextBlock Text="Значение:" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBox Text="{Binding Standard.StandardValue, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="3" Margin="5"/>

                <TextBlock Text="Код территории:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox Text="{Binding Standard.TerritoryCode, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="1" Margin="5"/>

                <TextBlock Text="Действует с:" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" FontWeight="Bold"/>
                <DatePicker SelectedDate="{Binding Standard.ValidFrom, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="3" Margin="5"/>

                <TextBlock Text="Действует по:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
                <DatePicker SelectedDate="{Binding Standard.ValidTo, UpdateSourceTrigger=PropertyChanged}" Grid.Row="2" Grid.Column="1" Margin="5"/>

                <StackPanel Grid.Row="3" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                    <Button Content="Добавить" Command="{Binding AddCommand}" Width="90" Height="30" Margin="5"
                            Background="#2E7D32" Foreground="White"/>
                    <Button Content="Обновить" Command="{Binding UpdateCommand}" Width="90" Height="30" Margin="5"
                            Background="#1565C0" Foreground="White"/>
                    <Button Content="Удалить" Command="{Binding DeleteCommand}" Width="90" Height="30" Margin="5"
                            Background="#D32F2F" Foreground="White"/>
                    <Button Content="Очистить" Command="{Binding ClearCommand}" Width="90" Height="30" Margin="5"
                            Background="#757575" Foreground="White"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Список нормативов -->
        <GroupBox Header="Список нормативов" Grid.Row="1">
            <DataGrid ItemsSource="{Binding Standards}" 
                      SelectedItem="{Binding SelectedStandard}"
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#F5F5F5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding StandardId}" Width="50"/>
                    <DataGridTextColumn Header="Тип норматива" Binding="{Binding StandardType}" Width="250"/>
                    <DataGridTextColumn Header="Значение" Binding="{Binding StandardValue, StringFormat=N2}" Width="100"/>
                    <DataGridTextColumn Header="Код территории" Binding="{Binding TerritoryCode}" Width="100"/>
                    <DataGridTextColumn Header="Действует с" Binding="{Binding ValidFrom, StringFormat=dd.MM.yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Действует по" Binding="{Binding ValidTo, StringFormat=dd.MM.yyyy}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- Кнопка Назад -->
        <Button Grid.Row="2" Content="◀ Назад" Click="BackButton_Click" Width="120" Height="35" Margin="5"
                Background="#1565C0" Foreground="White" HorizontalAlignment="Center"/>

        <!-- Статус -->
        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="Gray" FontSize="11" 
                   Margin="0,5,0,0" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
    </Grid>
</Window>