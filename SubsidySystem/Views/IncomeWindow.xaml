<Window x:Class="SubsidySystem.Views.IncomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ввод доходов" Height="650" Width="900"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Выбор заявителя -->
        <GroupBox Header="Выбор заявителя" Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Margin="10">
                <ComboBox ItemsSource="{Binding Citizens}" 
                          SelectedItem="{Binding SelectedCitizen}"
                          DisplayMemberPath="LastName" 
                          Margin="0,5"/>
            </StackPanel>
        </GroupBox>

        <!-- Выбор члена семьи -->
        <GroupBox Header="Выбор члена семьи" Grid.Row="1" Margin="0,0,0,10">
            <StackPanel Margin="10">
                <ComboBox ItemsSource="{Binding FamilyMembers}" 
                          SelectedItem="{Binding SelectedFamilyMember}"
                          Margin="0,5">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Run Text="{Binding LastName}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding FirstName}"/>
                                <Run Text=" ("/>
                                <Run Text="{Binding Relationship}"/>
                                <Run Text=")"/>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </GroupBox>

        <!-- Добавление дохода -->
        <GroupBox Header="Добавление дохода" Grid.Row="2" Margin="0,0,0,10">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Вид дохода:" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding IncomeTypes}" 
                          SelectedItem="{Binding SelectedIncomeType}" DisplayMemberPath="IncomeTypeName"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Сумма:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding Income.Amount, UpdateSourceTrigger=PropertyChanged}" Margin="5,0,0,0"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Период с:" VerticalAlignment="Center"/>
                <DatePicker Grid.Row="1" Grid.Column="1" SelectedDate="{Binding Income.PeriodStart}"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="Период по:" VerticalAlignment="Center"/>
                <DatePicker Grid.Row="1" Grid.Column="3" SelectedDate="{Binding Income.PeriodEnd}"/>

                <Button Grid.Row="2" Grid.ColumnSpan="4" Content="Добавить доход" 
                        Command="{Binding AddIncomeCommand}" Width="150" Height="30"
                        HorizontalAlignment="Center" Margin="0,10"/>
            </Grid>
        </GroupBox>

        <!-- Список доходов -->
        <GroupBox Header="Список доходов" Grid.Row="3" Margin="0,0,0,10">
            <DataGrid ItemsSource="{Binding Incomes}" AutoGenerateColumns="False"
                      SelectedItem="{Binding SelectedIncome}" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Вид дохода" Binding="{Binding IncomeType.IncomeTypeName}" Width="150"/>
                    <DataGridTextColumn Header="Сумма" Binding="{Binding Amount, StringFormat=N2}" Width="100"/>
                    <DataGridTextColumn Header="Период с" Binding="{Binding PeriodStart, StringFormat=dd.MM.yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Период по" Binding="{Binding PeriodEnd, StringFormat=dd.MM.yyyy}" Width="100"/>
                    <DataGridTemplateColumn Header="Удалить" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="X" 
                                        Command="{Binding DataContext.DeleteIncomeCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                        CommandParameter="{Binding}" 
                                        Background="Red" 
                                        Foreground="White" 
                                        Width="40"
                                        Height="25"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- Кнопки -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
            <Button Content="Сохранить все" Command="{Binding SaveAllCommand}" Width="120" Height="35" Margin="5"
                    Background="#2E7D32" Foreground="White"/>
            <Button Content="◀ Назад" Click="BackButton_Click" Width="120" Height="35" Margin="5"
                    Background="#1565C0" Foreground="White"/>
        </StackPanel>

        <!-- Статус -->
        <TextBlock Grid.Row="6" Text="{Binding StatusMessage}" Foreground="Gray" FontSize="11" TextWrapping="Wrap"/>
    </Grid>
</Window>