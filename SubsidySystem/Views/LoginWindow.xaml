<Window x:Class="SubsidySystem.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация - АС Субсидии-ЖКУ" 
        Height="456" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5" 
                                BorderBrush="#1B5E20" 
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1B5E20"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1565C0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
        </Style>

        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid Background="#F5F5F5">
            <Grid.RowDefinitions>
                <RowDefinition Height="120"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="#2E7D32">
                <StackPanel VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="АС «Субсидии-ЖКУ»" 
                               FontSize="22" 
                               FontWeight="Bold" 
                               Foreground="White"/>
                    <TextBlock Text="Автоматизированная система учета и расчета субсидий и компенсаций ЖКУ" 
                               FontSize="12" 
                               Foreground="#E0E0E0"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Форма авторизации -->
            <Border Grid.Row="1" 
                    Background="White" 
                    CornerRadius="10" 
                    Margin="40,20,40,0"
                    Padding="20">

                <StackPanel>
                    <TextBlock Text="Вход в систему" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="#2E7D32"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <!-- Поле Логин -->
                    <TextBlock Text="Логин" 
                               FontSize="13" 
                               Foreground="#616161"
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="LoginTextBox" 
                             Style="{StaticResource ModernTextBox}"
                             Margin="0,0,0,15"/>

                    <!-- Поле Пароль -->
                    <TextBlock Text="Пароль" 
                               FontSize="13" 
                               Foreground="#616161"
                               Margin="0,0,0,5"/>
                    <PasswordBox x:Name="PasswordBox" 
                                 Style="{StaticResource ModernPasswordBox}"
                                 Margin="0,0,0,20"
                                 KeyDown="PasswordBox_KeyDown"/>

                    <!-- Кнопка входа -->
                    <Button x:Name="LoginButton" 
                            Content="Войти в систему" 
                            Style="{StaticResource ModernButton}"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,0"
                            Click="LoginButton_Click"/>

                    <!-- Статус сообщения -->
                    <TextBlock x:Name="StatusTextBlock" 
                               Text="" 
                               Foreground="Red" 
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- Футер -->
            <TextBlock Grid.Row="5" 
                       Text="ГКУ Оренбургской области «Центр социальной поддержки населения»" 
                       FontSize="10" 
                       Foreground="#9E9E9E"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,10"/>
        </Grid>
    </Grid>
</Window>