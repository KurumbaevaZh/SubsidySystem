<Window x:Class="SubsidySystem.Views.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Формирование отчетов" Height="550" Width="900"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Параметры отчета -->
        <GroupBox Header="Параметры отчета" Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="10" HorizontalAlignment="Center">
                <TextBlock Text="Тип отчета:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox ItemsSource="{Binding ReportTypes}" SelectedItem="{Binding SelectedReportType}" Width="150" Margin="0,0,20,0"/>

                <TextBlock Text="Год:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox ItemsSource="{Binding Years}" SelectedItem="{Binding SelectedYear}" Width="80" Margin="0,0,20,0"/>

                <TextBlock Text="Месяц:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox ItemsSource="{Binding Months}" SelectedItem="{Binding SelectedMonth}" Width="80"/>
            </StackPanel>
        </GroupBox>

        <!-- Кнопки -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <Button Content="Сформировать отчет" Command="{Binding GenerateReportCommand}" Width="150" Height="35" Margin="5"
                    Background="#2E7D32" Foreground="White"/>
            <Button Content="Экспорт в Excel" Command="{Binding ExportExcelCommand}" Width="150" Height="35" Margin="5"
                    Background="#1565C0" Foreground="White"/>
            <Button Content="◀ Назад" Click="BackButton_Click" Width="150" Height="35" Margin="5"
                    Background="#757575" Foreground="White"/>
        </StackPanel>

        <!-- Результат -->
        <GroupBox Header="Результат" Grid.Row="2" Margin="0,10">
            <DataGrid ItemsSource="{Binding ReportData}" AutoGenerateColumns="True" 
                      CanUserAddRows="False" IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#F5F5F5"/>
        </GroupBox>

        <!-- Статус -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Foreground="Gray" FontSize="11" TextWrapping="Wrap"/>
    </Grid>
</Window>