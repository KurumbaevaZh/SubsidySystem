<Window x:Class="SubsidySystem.Views.UsersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление пользователями" Height="550" Width="800"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Форма добавления/редактирования -->
        <GroupBox Header="Данные пользователя" Grid.Row="0" Margin="0,0,0,10">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Логин:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBox Text="{Binding User.Login, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1" Margin="5"/>

                <TextBlock Text="Пароль:" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" FontWeight="Bold"/>
                <PasswordBox x:Name="PasswordBox" Grid.Row="0" Grid.Column="3" Margin="5"/>

                <TextBlock Text="ФИО:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBox Text="{Binding User.FullName, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="1" Margin="5"/>

                <TextBlock Text="Роль:" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" FontWeight="Bold"/>
                <ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding User.Role}" Grid.Row="1" Grid.Column="3" Margin="5"/>

                <TextBlock Text="Активен:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
                <CheckBox IsChecked="{Binding User.IsActive}" Grid.Row="2" Grid.Column="1" Margin="5" VerticalAlignment="Center"/>

                <StackPanel Grid.Row="3" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                    <Button Content="Добавить" Command="{Binding AddCommand}" Width="90" Height="30" Margin="5"
                            Background="#2E7D32" Foreground="White"/>
                    <Button Content="Обновить" Command="{Binding UpdateCommand}" Width="90" Height="30" Margin="5"
                            Background="#1565C0" Foreground="White"/>
                    <Button Content="Удалить" Command="{Binding DeleteCommand}" Width="90" Height="30" Margin="5"
                            Background="#D32F2F" Foreground="White"/>
                    <Button Content="Сброс пароля" Command="{Binding ResetPasswordCommand}" Width="100" Height="30" Margin="5"
                            Background="#FF8F00" Foreground="White"/>
                    <Button Content="Очистить" Command="{Binding ClearCommand}" Width="90" Height="30" Margin="5"
                            Background="#757575" Foreground="White"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Список пользователей -->
        <GroupBox Header="Список пользователей" Grid.Row="1">
            <DataGrid ItemsSource="{Binding Users}" 
                      SelectedItem="{Binding SelectedUser}"
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#F5F5F5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding UserId}" Width="50"/>
                    <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="120"/>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="200"/>
                    <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="100"/>
                    <DataGridTextColumn Header="Активен" Width="80">
                        <DataGridTextColumn.Binding>
                            <Binding Path="IsActive" StringFormat="{}{0:Да;Нет}"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Дата создания" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Последний вход" Binding="{Binding LastLogin, StringFormat=dd.MM.yyyy HH:mm}" Width="130"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- Статус -->
        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="Gray" FontSize="11" Margin="0,5,0,0"/>
    </Grid>
</Window>