<Window x:Class="SubsidySystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АС Субсидии-ЖКУ" 
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="80"/>
            <Setter Property="Width" Value="180"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                BorderBrush="#1B5E20" 
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1B5E20"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1565C0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LogoutButton" TargetType="Button">
            <Setter Property="Background" Value="#D32F2F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5" 
                                BorderBrush="#B71C1C" 
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B71C1C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AdminButton" TargetType="Button">
            <Setter Property="Background" Value="#1565C0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="80"/>
            <Setter Property="Width" Value="180"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                BorderBrush="#0D47A1" 
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0D47A1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ReportButton" TargetType="Button">
            <Setter Property="Background" Value="#FF8F00"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="80"/>
            <Setter Property="Width" Value="180"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                BorderBrush="#E65100" 
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E65100"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2E7D32"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с информацией о пользователе -->
        <Border Grid.Row="0" Background="#2E7D32" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="АС «Субсидии-ЖКУ»" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="White"/>
                    <TextBlock Text=" | " FontSize="14" Foreground="White"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Пользователь: " FontSize="12" Foreground="#E0E0E0"/>
                        <TextBlock x:Name="UserNameTextBlock" Text="Не авторизован" FontSize="12" 
                                   FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text=" (" FontSize="12" Foreground="#E0E0E0"/>
                        <TextBlock x:Name="UserRoleTextBlock" Text="гость" FontSize="12" 
                                   Foreground="#FFD54F"/>
                        <TextBlock Text=")" FontSize="12" Foreground="#E0E0E0"/>
                    </StackPanel>
                </StackPanel>

                <Button x:Name="LogoutButton" Grid.Column="1" 
                        Content="Выйти" 
                        Style="{StaticResource LogoutButton}"
                        Click="LogoutButton_Click"/>
            </Grid>
        </Border>

        <!-- Основная область с кнопками меню -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#F5F5F5">
            <StackPanel Margin="20">

                <!-- Основные функции -->
                <TextBlock Text="Основные функции" Style="{StaticResource SectionTitle}"/>
                <WrapPanel>
                    <Button Content="📋 Регистрация заявителя" 
                            Style="{StaticResource MenuButton}"
                            Click="RegisterCitizen_Click"/>

                    <Button Content="👨‍👩‍👧‍👦 Члены семьи" 
                            Style="{StaticResource MenuButton}"
                            Click="FamilyMembers_Click"/>

                    <Button Content="💰 Ввод доходов" 
                            Style="{StaticResource MenuButton}"
                            Click="EnterIncomes_Click"/>

                    <Button Content="🧮 Расчет субсидии" 
                            Style="{StaticResource MenuButton}"
                            Click="CalculateSubsidy_Click"/>

                    <Button Content="📊 Формирование отчетов" 
                            Style="{StaticResource ReportButton}"
                            Click="GenerateReports_Click"/>
                    
                </WrapPanel>

                
                
                <!-- Панель администратора (видна только администратору) -->
                <StackPanel x:Name="AdminPanel" Visibility="Collapsed" Margin="0,20,0,0">
                    <TextBlock Text="Администрирование" Style="{StaticResource SectionTitle}"/>
                    <WrapPanel>
                        <Button Content="⚙️ Справочники" 
                                Style="{StaticResource AdminButton}"
                                Click="ManageDictionaries_Click"/>

                        <Button Content="👥 Управление пользователями" 
                                Style="{StaticResource AdminButton}"
                                Click="ManageUsers_Click"/>

                        <Button Content="📋 Нормативы" 
                                Style="{StaticResource AdminButton}"
                                Click="ManageStandards_Click"/>
                    </WrapPanel>
                </StackPanel>

                <!-- Панель отчетов (видна руководителю и администратору) -->
                <StackPanel x:Name="ReportsPanel" Visibility="Collapsed" Margin="0,20,0,0">
                    <TextBlock Text="Отчеты и аналитика" Style="{StaticResource SectionTitle}"/>
                    <WrapPanel>
                        <Button Content="📈 Статистические отчеты" 
                                Style="{StaticResource ReportButton}"
                                Click="StatisticalReports_Click"/>

                        <Button Content="📑 Реестры выплат" 
                                Style="{StaticResource ReportButton}"
                                Click="PaymentRegistries_Click"/>
                    </WrapPanel>
                </StackPanel>

                <TextBlock Text="Для получения подробной информации по каждой функции\nобратитесь к руководству пользователя" 
                           FontSize="11" 
                           Foreground="#9E9E9E"
                           Margin="0,30,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Нижняя панель статуса -->
        <Border Grid.Row="2" Background="#E0E0E0" Padding="10" BorderBrush="#BDBDBD" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusTextBlock" Text="Готов к работе" 
                           FontSize="11" 
                           Foreground="#616161"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1" Text="© ГКУ Оренбургской области «Центр социальной поддержки населения»" 
                           FontSize="10" 
                           Foreground="#9E9E9E"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>